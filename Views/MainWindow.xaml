<Window x:Class="Painel240hz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="240Hz Optimizer"
        Height="400"
        Width="600"
        Background="#0f0f0f">

    <Grid>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="CPU"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="cpuText"
                       Text="0%"
                       FontSize="22"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="RAM"
                       Margin="0,10,0,0"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="ramText"
                       Text="0%"
                       FontSize="22"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <ProgressBar x:Name="progressBar"
                         Width="300"
                         Height="20"
                         Margin="0,20,0,0"/>

            <TextBlock x:Name="txtStatus"
                       Text="Sistema pronto"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>

            <Button Content="Iniciar Otimização"
                    Width="200"
                    Height="40"
                    Margin="0,20,0,0"
                    Click="StartOptimization"/>

        </StackPanel>

    </Grid>

</Window>